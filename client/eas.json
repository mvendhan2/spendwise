{
  "cli": {
    "version": ">= 12.0.0"
  },
  "build": {
    "development": {
      "developmentClient": true,
      "distribution": "internal",
      "env": {
        "EXPO_PUBLIC_API_URL": "https://spendwise-api.fly.dev/api"
      }
    },
    "preview": {
      "distribution": "internal",
      "android": {
        "buildType": "apk"
      },
      "ios": {
        "simulator": true
      },
      "env": {
        "EXPO_PUBLIC_API_URL": "https://spendwise-api.fly.dev/api"
      }
    },
    "preview-device": {
      "distribution": "internal",
      "android": {
        "buildType": "apk"
      },
      "env": {
        "EXPO_PUBLIC_API_URL": "https://spendwise-api.fly.dev/api"
      }
    },
    "production": {
      "env": {
        "EXPO_PUBLIC_API_URL": "https://spendwise-api.fly.dev/api"
      }
    }
  },
  "submit": {
    "production": {}
  }
}
